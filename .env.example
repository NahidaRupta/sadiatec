# =============================================================================
# Saidatech — Environment Variables
# Copy this file to apps/saidatech/.env.local and fill in real values.
# NEVER commit .env.local to version control.
# =============================================================================

# Database (Neon Postgres — create project at https://neon.tech)
DATABASE_URI=postgresql://user:password@ep-example.us-east-1.aws.neon.tech/neondb?sslmode=require

# Payload CMS (generate with: openssl rand -hex 32)
PAYLOAD_SECRET=your-payload-secret-minimum-32-characters

# AI Corpus endpoint bearer token (generate with: openssl rand -hex 32)
# Required even when features.aiAgent = false — the route exists and must be protected.
AI_CORPUS_SECRET=your-ai-corpus-secret-minimum-32-characters

# Resend (Email delivery — https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Cloudflare Turnstile (Spam protection — https://dash.cloudflare.com/?to=/:account/turnstile)
TURNSTILE_SITE_KEY=0x4AAAAAAAxxxxxxxxxxxxxxx
TURNSTILE_SECRET_KEY=0x4AAAAAAAxxxxxxxxxxxxxxx

# Cloudflare R2 (Media storage — https://dash.cloudflare.com/?to=/:account/r2)
CLOUDFLARE_R2_BUCKET=saidatech-media
CLOUDFLARE_R2_ACCESS_KEY_ID=your-r2-access-key-id
CLOUDFLARE_R2_SECRET_ACCESS_KEY=your-r2-secret-access-key
# Format: https://<account-id>.r2.cloudflarestorage.com
CLOUDFLARE_R2_ENDPOINT=https://your-account-id.r2.cloudflarestorage.com

# Public server URL — used by Payload to generate absolute media URLs
# Local dev: http://localhost:3000 | Production: https://sadiatec.com
NEXT_PUBLIC_SERVER_URL=http://localhost:3000
