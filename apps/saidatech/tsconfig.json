{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "paths": {
      "@/*": [
        "./src/*"
      ],
      "@site/*": [
        "./*"
      ],
      "@saidatech/cms-core/schema": [
        "../../packages/cms-core/src/schema/site-config.ts"
      ],
      "@saidatech/cms-core/blocks": [
        "../../packages/cms-core/src/blocks/index.ts"
      ],
      "@saidatech/cms-core/i18n": [
        "../../packages/cms-core/src/i18n/routing-factory.ts"
      ],
      "@saidatech/cms-core/payload/config-factory": [
        "../../packages/cms-core/src/payload/config-factory.ts"
      ],
      "@saidatech/cms-core/tokens": [
        "../../packages/cms-core/src/tokens/index.ts"
      ],
      "@saidatech/cms-core/seed": [
        "../../packages/cms-core/src/seed/utils.ts"
      ],
      "@saidatech/cms-core/styles": [
        "../../packages/cms-core/src/styles/globals.css"
      ],
      "@saidatech/cms-core/components/ui": [
        "../../packages/cms-core/src/components/ui/index.ts"
      ],
      "@saidatech/cms-core/lib/motion": [
        "../../packages/cms-core/src/lib/motion.ts"
      ],
      "@saidatech/cms-core/components/LanguageSwitcher": [
        "../../packages/cms-core/src/components/LanguageSwitcher.tsx"
      ],
      "@payload-config": [
        "./payload.config.ts"
      ]
    },
    "allowJs": true,
    "incremental": true,
    "esModuleInterop": true
  },
  "include": [
    "*.ts",
    "*.tsx",
    "next.config.ts",
    "src/**/*.ts",
    "src/**/*.tsx",
    ".next/types/**/*.ts"
  ],
  "exclude": [
    "node_modules",
    ".next"
  ]
}
